classDiagram

class Game {
    -Board board
    -Player players[2]
    -int currentPlayer
    +startGame()
    +takeTurn()
    +checkWinCondition() bool
}

class Board {
    -ColorEnum tokens[5][5]
    -Deck tier1
    -Deck tier2
    -Deck tier3
    -vector~Card~ visibleTier1
    -vector~Card~ visibleTier2
    -vector~Card~ visibleTier3
    -vector~Card~ royals
    -vector~ColorEnum~ bagOfTokens
    -int boardPrivileges
    +takeTokens(vector~Position~) vector~ColorEnum~
    +refillCards()
}

class Player {
    -array~int~ tokens
    -array~int~ bonuses
    -vector~Card~ purchasedCards
    -vector~Card~ reservedCards
    -int privileges
    -int totalPoints
    -int crowns
    +canAfford(Card) bool
    +buyCard(Card)
    +reserveCard(Card)
}

class Deck {
    -stack~Card~ cards
    +draw() Card
    +shuffle()
}

class Card {
    +int id
    +ColorEnum bonusColor
    +Cost cost
    +int points
    +int crowns
    +AbilityEnum ability
}

class Cost {
    -array~int~ cost
}

class Position {
    +int x
    +int y
}

Game --> Board
Game --> Player
Board --> Deck
Board --> Card
Player --> Card
Card --> Cost