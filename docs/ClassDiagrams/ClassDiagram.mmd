classDiagram
    class Game {
        -players : Player[2]
        -board : Board
        -currentPlayerIndex : int
        -winningPlayer : int
        +startNewGame()
        +processTurn()
        +checkWinConditions() : bool
        +transferToken(from, to, pos)
    }
    class Player {
        -boughtCards : vector~Card~
        -reservedCards : vector~Card~
        -tokens : int[6]
        -privileges : int
        -totalPoints : int
        -crowns : int
        +canAfford(Card) : bool
        +addPrivilege() : bool
    }
    class Board {
        -grid : Token*[5][5]
        -tier1 : deck~Card~
        -tier2 : deck~Card~
        -tier3 : deck~Card~
        -royals : vector~Card~
        -privileges : int
        +refillGrid()
        +isValidPick(pos1, pos2, pos3) : bool
    }
    class Card {
        +color : ColorEnum
        +points : int
        +crowns : int
        +cost : int[6]
        +ability : AbilityEnum
    }